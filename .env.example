# --- Atrucks ---
# Скопируйте значение заголовка Cookie из DevTools (запрос к
# /carrier/auctions/lots/general/quick/) целиком, как одну строку.
# Обязательно содержит как минимум sessionid и csrftoken.
ATRUCKS_COOKIE=__ddg1_=...; sessionid=...; csrftoken=...

# --- ATI.SU ---
ATI_TOKEN=2be9c4b812e045e6a7e6b117e88fb8ee
ATI_FIRM_ID=701329
ATI_CONTACT_ID=148
# UUID "доски" публикации (см. существующую систему)
ATI_BOARD_ID=a0a0a0a0a0a0a0a0a0a0a0a0

# --- Расписание ---
# Интервал опроса Atrucks в минутах
POLL_INTERVAL_MINUTES=10

# --- БД ---
# Путь к файлу SQLite (на Railway указывайте путь внутри volume)
DB_PATH=/data/atrucks-ati.sqlite

# --- Прочее ---
PORT=3000
